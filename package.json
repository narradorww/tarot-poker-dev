{
  "name": "tarot-dev-poker",
  "version": "1.0.0",
  "description": "A mystical planning poker app with Tarot-themed cards for development teams",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "start": "npm start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
